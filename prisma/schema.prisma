generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  TEACHER
}

enum GradeComponent {
  QUIZ
  ASSIGNMENT
  EXAM
}

// Staff accounts only (Admin/Teacher). Students have no login.
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         Role
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  teacher      Teacher?
}

model Teacher {
  id         String               @id @default(cuid())
  userId     String               @unique
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeId String?              @unique
  assignments TeachingAssignment[]
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
}

model Student {
  id          String       @id @default(cuid())
  studentId   String       @unique
  name        String
  enrollments Enrollment[]
  gradeEntries GradeEntry[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model SchoolYear {
  id          String                @id @default(cuid())
  label       String                @unique // e.g. "2025-2026"
  isActive    Boolean               @default(false)
  sections    Section[]
  subjects    Subject[]
  enrollments Enrollment[]
  assignments TeachingAssignment[]
  createdAt   DateTime              @default(now())
}

// A grade/room, e.g. "Grade 1 - A"
model Section {
  id           String                @id @default(cuid())
  name         String
  schoolYearId String
  schoolYear   SchoolYear            @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  enrollments  Enrollment[]
  assignments  TeachingAssignment[]
  createdAt    DateTime              @default(now())

  @@unique([name, schoolYearId])
}

// A subject defined once per school year, e.g. "Tawheed", "Fiqh".
// Reused across multiple sections via TeachingAssignment.
model Subject {
  id           String                @id @default(cuid())
  name         String
  schoolYearId String
  schoolYear   SchoolYear            @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  assignments  TeachingAssignment[]
  createdAt    DateTime              @default(now())

  @@unique([name, schoolYearId])
}

model Enrollment {
  id           String     @id @default(cuid())
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sectionId    String
  section      Section    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  schoolYearId String
  schoolYear   SchoolYear @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([studentId, sectionId, schoolYearId])
}

// Connects a Teacher to a Subject for a specific Section (grade/room) within a School Year.
// e.g. Ustadh Ahmad teaches Tawheed in Grade 1-A; a different assignment may have
// Ustadh Bilal teaching Tawheed in Grade 1-B in the same school year.
model TeachingAssignment {
  id           String      @id @default(cuid())
  teacherId    String
  teacher      Teacher     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subjectId    String
  subject      Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  sectionId    String
  section      Section     @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  schoolYearId String
  schoolYear   SchoolYear  @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  gradeItems   GradeItem[]
  createdAt    DateTime    @default(now())

  @@unique([subjectId, sectionId, schoolYearId])
}

// An individual gradable item, e.g. "Quiz 1", "Assignment 2", "Midterm Exam"
// Scoped to a TeachingAssignment (subject taught in a specific section).
// Fixed weighting: QUIZ 20%, ASSIGNMENT 20%, EXAM 60% (applied at aggregation time)
model GradeItem {
  id                   String             @id @default(cuid())
  teachingAssignmentId String
  teachingAssignment   TeachingAssignment @relation(fields: [teachingAssignmentId], references: [id], onDelete: Cascade)
  title                String             // e.g. "Quiz 1"
  component            GradeComponent
  maxScore             Float              @default(100)
  entries              GradeEntry[]
  createdAt            DateTime           @default(now())
}

model GradeEntry {
  id          String    @id @default(cuid())
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  gradeItemId String
  gradeItem   GradeItem @relation(fields: [gradeItemId], references: [id], onDelete: Cascade)
  score       Float
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([studentId, gradeItemId])
}
